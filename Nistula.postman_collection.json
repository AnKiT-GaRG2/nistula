    "name": "Nistula — Guest Message Handler",
    "description": "## Nistula Guest Message Handler API\n\nEnd-to-end Postman collection covering all routes, all query types, validation errors, and edge cases.\n\n### Setup\n1. Import this collection into Postman\n2. The `base_url` collection variable defaults to `http://localhost:3000` — change it if your server runs elsewhere\n3. Start the server: `npm start` in the project directory\n4. Run the **Collection Runner** in the order below — each folder builds on the previous\n\n### Folder run order\n| # | Folder | Purpose |\n|---|---|---|\n| 1 | Health Check | Verify server is up before running anything else |\n| 2 | Happy Path — All Query Types | One request per query_type; validates full response schema |\n| 3 | Validation Errors | Confirm 4xx handling for bad inputs |\n| 4 | Edge Cases | Boundary conditions — empty body, oversized payload, unknown route |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL of the running server. Change this if you deploy remotely."
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('base_url')) {",
          "    pm.collectionVariables.set('base_url', 'http://localhost:3000');",
          "}"
        ]
      }
    }
  ],
  "item": [

    {
      "name": "1 — Health Check",
      "description": "Verify the server is live and returning expected fields before running any webhook tests.",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Liveness probe. Confirms the server is up, returns uptime and a UTC timestamp."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status field is ok', () => pm.expect(json.status).to.equal('ok'));",
                  "pm.test('timestamp is an ISO string', () => pm.expect(json.timestamp).to.match(/^\\d{4}-\\d{2}-\\d{2}T/));",
                  "pm.test('uptimeSeconds is a number', () => pm.expect(json.uptimeSeconds).to.be.a('number').and.to.be.at.least(0));",
                  "pm.test('X-Request-Id header present', () => pm.expect(pm.response.headers.get('X-Request-Id')).to.be.a('string').and.not.empty);",
                  "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "2 — Happy Path (All Query Types)",
      "description": "One request per query_type. Run these in order — they cover all 6 classification branches and validate the full response contract.",
      "item": [
        {
          "name": "01 · Pre-Sales Availability — WhatsApp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"whatsapp\",\n  \"guest_name\": \"Rahul Sharma\",\n  \"message\": \"Is the villa available from April 20 to 24? What is the rate for 2 adults?\",\n  \"timestamp\": \"2026-05-05T10:30:00Z\",\n  \"booking_ref\": \"NIS-2024-0891\",\n  \"property_id\": \"villa-b1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/webhook/message",
              "host": ["{{base_url}}"],
              "path": ["webhook", "message"]
            },
            "description": "Combined availability + pricing query arriving via WhatsApp. The classifier assigns `pre_sales_availability` because complaint and check-in keywords are absent and 'available' matches first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('message_id is a UUID', () => pm.expect(json.message_id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i));",
                  "pm.test('query_type = pre_sales_availability', () => pm.expect(json.query_type).to.equal('pre_sales_availability'));",
                  "pm.test('drafted_reply is non-empty', () => pm.expect(json.drafted_reply).to.be.a('string').and.not.empty);",
                  "pm.test('confidence_score in [0,1]', () => {",
                  "    pm.expect(json.confidence_score).to.be.a('number');",
                  "    pm.expect(json.confidence_score).to.be.at.least(0);",
                  "    pm.expect(json.confidence_score).to.be.at.most(1);",
                  "});",
                  "pm.test('action is one of valid values', () => pm.expect(['auto_send','agent_review','escalate']).to.include(json.action));",
                  "pm.test('X-Request-Id header present', () => pm.expect(pm.response.headers.get('X-Request-Id')).to.be.a('string').and.not.empty);",
                  "",
                  "console.log('confidence:', json.confidence_score, '| action:', json.action);",
                  "console.log('reply:', json.drafted_reply.slice(0, 100));"
                ]
              }
            }
          ]
        },

