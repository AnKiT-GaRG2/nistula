    {
      "name": "3 — Validation Errors",
      "description": "All requests in this folder should return 4xx. Confirms the validation layer works correctly before any Claude call is made.",
      "item": [
        {
          "name": "01 · Missing Required Fields → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"whatsapp\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/webhook/message",
              "host": ["{{base_url}}"],
              "path": ["webhook", "message"]
            },
            "description": "Only `source` is provided. All other required fields (guest_name, message, timestamp, booking_ref, property_id) are missing. Expect a 400 with a list of missing fields in the error message."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('error field is present', () => pm.expect(json.error).to.be.a('string').and.not.empty);",
                  "pm.test('code is VALIDATION_ERROR', () => pm.expect(json.code).to.equal('VALIDATION_ERROR'));",
                  "pm.test('requestId is present', () => pm.expect(json.requestId).to.be.a('string').and.not.empty);",
                  "pm.test('error mentions missing fields', () => pm.expect(json.error.toLowerCase()).to.include('missing'));"
                ]
              }
            }
          ]
        },

