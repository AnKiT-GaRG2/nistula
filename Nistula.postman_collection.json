    {
      "name": "4 — Edge Cases",
      "description": "Boundary conditions: empty body, completely unknown route, and the 404 handler.",
      "item": [
        {
          "name": "01 · Empty Body → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/webhook/message",
              "host": ["{{base_url}}"],
              "path": ["webhook", "message"]
            },
            "description": "Valid JSON but completely empty object — all required fields are missing. Expect 400 VALIDATION_ERROR listing all 6 missing fields."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('code is VALIDATION_ERROR', () => pm.expect(json.code).to.equal('VALIDATION_ERROR'));",
                  "pm.test('requestId is present', () => pm.expect(json.requestId).to.be.a('string').and.not.empty);",
                  "",
                  "const allFields = ['source','guest_name','message','timestamp','booking_ref','property_id'];",
                  "pm.test('error mentions multiple missing fields', () => {",
                  "    const mentioned = allFields.filter(f => json.error.includes(f));",
                  "    pm.expect(mentioned.length).to.be.at.least(3);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "02 · Unknown Route → 404",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/webhook/nonexistent",
              "host": ["{{base_url}}"],
              "path": ["webhook", "nonexistent"]
            },
            "description": "Hits a route that does not exist. The notFound middleware should return 404 NOT_FOUND with the method and path in the error message."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('code is NOT_FOUND', () => pm.expect(json.code).to.equal('NOT_FOUND'));",
                  "pm.test('error mentions the path', () => pm.expect(json.error).to.include('nonexistent'));",
                  "pm.test('requestId is present', () => pm.expect(json.requestId).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        },

        {
          "name": "03 · GET on webhook endpoint → 404",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/webhook/message",
              "host": ["{{base_url}}"],
              "path": ["webhook", "message"]
            },
            "description": "The /webhook/message route only accepts POST. A GET to the same path should hit the 404 catch-all since there is no GET handler registered for it."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('code is NOT_FOUND', () => pm.expect(pm.response.json().code).to.equal('NOT_FOUND'));"
                ]
              }
            }
          ]
        },

        {
          "name": "04 · Whitespace-only message field → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"whatsapp\",\n  \"guest_name\": \"Test User\",\n  \"message\": \"   \",\n  \"timestamp\": \"2026-05-05T10:00:00Z\",\n  \"booking_ref\": \"NIS-2024-0001\",\n  \"property_id\": \"villa-b1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/webhook/message",
              "host": ["{{base_url}}"],
              "path": ["webhook", "message"]
            },
            "description": "All fields present but `message` is only whitespace. Validation trims then checks, so this should fail with 400 — an empty message cannot be classified or replied to."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('code is VALIDATION_ERROR', () => pm.expect(json.code).to.equal('VALIDATION_ERROR'));",
                  "pm.test('requestId is present', () => pm.expect(json.requestId).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ]
        }
      ]
    }

  ]
}
