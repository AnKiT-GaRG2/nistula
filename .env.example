# Neon (PostgreSQL) connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Anthropic / Claude API key (required for Claude-backed replies)
# Without this, the server starts but uses deterministic fallback reply templates.
ANTHROPIC_API_KEY=your_key_here
# Optional alias supported by the app
# CLAUDE_API_KEY=your_key_here

# Claude model to use for drafting replies
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# HTTP port the server listens on
PORT=3000

# Maximum requests per IP per minute (in-memory sliding window)
RATE_LIMIT_PER_MINUTE=60
