# ── AI Providers ─────────────────────────────────────────────────────────────
# Tried in order: Claude → Groq → Gemini → text fallback.
# At least one key is required. All three gives maximum resilience.

# Primary: Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Secondary: Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tertiary: Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Database ─────────────────────────────────────────────────────────────────
# Neon (or any PostgreSQL) connection string
DATABASE_URL=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
RATE_LIMIT_PER_MINUTE=60
